# ─────────────────────────────────────────────────────────────
# Solace Skin — environment variables
# Copy this file to `.env.local` and fill in what you have.
# Everything is OPTIONAL: with no keys set, the site runs in
# "fallback mode" — bookings/enquiries save to a local JSON file
# and emails are logged to the server console.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO canonical + Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Business contact (shown on site + used as email recipient)
NEXT_PUBLIC_BUSINESS_EMAIL=solaceskin.gh@gmail.com
NEXT_PUBLIC_BUSINESS_PHONE=+233000000000
NEXT_PUBLIC_WHATSAPP_NUMBER=233000000000

# ── Supabase (database) ──────────────────────────────────────
# Leave blank to use the local JSON fallback store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (transactional email) ─────────────────────────────
# Leave blank to log emails to the console instead of sending.
RESEND_API_KEY=
RESEND_FROM="Solace Skin <bookings@solaceskin.com>"

# ── Cloudinary (image management, optional) ──────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Admin panel ──────────────────────────────────────────────
# Simple shared passcode gate for the /admin dashboard.
ADMIN_PASSCODE=change-me-please
